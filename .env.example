# ─── ERPNext / Forms Pro connection (World Cup Prediction) ───────────────
# The app submits entries via the Forms Pro public (GUEST) endpoint, so NO API
# key or secret is needed for storing entries — just the form id.
# Copy this file to `.env.local` for local dev; set the same vars in Netlify for
# production. See ERP_SETUP.md for how to create the form and get its id.

# Base URL of the ERPNext site hosting the Forms Pro form.
ERP_URL=https://erp.elbrit.org

# Forms Pro Form id of YOUR World Cup Prediction form.
# REQUIRED — until this is set, ERP submission is skipped (entries are still
# saved locally + logged). Get it from the form's URL / Form doc (see ERP_SETUP.md).
FORMS_PRO_FORM_ID=

# ─── Raven channel notification (optional) ───────────────────────────────
# Posts a message to a Raven channel on each submit. Raven's send API needs auth,
# so set an API key/secret of a user (or bot) that is a MEMBER of the channel.
# Leave blank to disable notifications.
RAVEN_API_KEY=
RAVEN_API_SECRET=
# Raven Channel name (the doc name, not the display label).
RAVEN_CHANNEL_ID=Elbrit Life Sciences-pmt
